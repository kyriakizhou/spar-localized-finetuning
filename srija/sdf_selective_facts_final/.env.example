# Required for submitting OpenWeights finetune and inference jobs.
OPENWEIGHTS_API_KEY=

# Required for LLM judging in evaluate.py.
OPENAI_API_KEY=

# Required by OpenWeights workers when pushing merged finetuned models to HF.
HF_TOKEN=

# Set at least one of these if it is not already configured in OpenWeights org secrets.
HF_ORG=
HF_USER=

# Only needed if you manage your own OpenWeights/RunPod workers from this machine.
RUNPOD_API_KEY=

# Usually not needed; OpenWeights has hosted defaults.
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
